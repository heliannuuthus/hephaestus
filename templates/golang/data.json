{
  "variables": {
    "inputs": [
      {
        "name": "workdir",
        "default": "./",
        "desc": "Specify all of golang steps where are run",
        "type": "string",
        "required": "false"
      },
      {
        "name": "goversion",
        "default": "1.23.6",
        "desc": "Specify go version",
        "type": "string",
        "required": "false"
      },
      {
        "name": "entrance",
        "default": "./main.go",
        "desc": "Specify main.go relative path",
        "type": "string",
        "required": "false"
      }
    ],
    "secrets": [],
    "outputs": []
  },
  "lint": {},
  "security": {
    "upload": {
      "name": "gosec-report",
      "paths": ["${{ inputs.workdir }}build/gosec-report.json"]
    }
  },
  "build": {
    "download": {
      "name": "gosec-report",
      "paths": ["${{ inputs.workdir }}build/gosec-report.json"]
    },
    "upload": {
      "name": "targets",
      "paths": ["${{ inputs.workdir }}build/"]
    }
  }
}
