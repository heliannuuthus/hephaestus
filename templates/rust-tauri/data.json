{
  "workdir": "{{ inputs.workdir }}",
  "rust_workdir": "{{ inputs.workdir }}/src-tauri",
  "variables": {
    "inputs": [
      {
        "name": "workdir",
        "default": "./",
        "desc": "Specify all of node steps where are run",
        "type": "string",
        "required": "false"
      },
      {
        "name": "node",
        "required": "false",
        "default": "lts/*",
        "type": "string",
        "desc": "Specify node version, default: lts"
      },
      {
        "name": "toolchain",
        "required": "false",
        "default": "stable",
        "type": "string",
        "desc": "Specify rust toolchain version, default: stable"
      },
      {
        "name": "build",
        "required": "false",
        "default": "build",
        "type": "string",
        "desc": "Specify build command"
      },
      {
        "name": "test",
        "required": "false",
        "type": "string",
        "desc": "Specify test command"
      }
    ],
    "secrets": [],
    "outputs": []
  },
  "setup": {
    "apt": {
      "packages": [
        "libwebkit2gtk-4.0-dev",
        "patchelf",
        "build-essential",
        "curl",
        "wget",
        "file",
        "libayatana-appindicator3-dev",
        "libglib2.0-dev",
        "libssl-dev",
        "librsvg2-dev",
        "libgdk3.0-cil",
        "libatk1.0-dev",
        "libgtk-3-dev"
      ],
      "version": "rust-tauri-ci"
    }
  }
}
