{
  "variables": {
    "inputs": [
      {
        "name": "workdir",
        "default": "./",
        "desc": "Specify all of rust steps where are run",
        "type": "string",
        "required": "false"
      },
      {
        "name": "toolchain",
        "default": "nightly",
        "desc": "Specify rust toolchain",
        "type": "string",
        "required": "false"
      },
      {
        "name": "targets",
        "default": "x86_64-unknown-linux-gnu",
        "desc": "Specify rust toolchain",
        "type": "string",
        "required": "false"
      }
    ],
    "secrets": [],
    "outputs": []
  },
  "setup": {
    "apt": {
      "packages": [
        "libwebkit2gtk-4.0-dev",
        "build-essential",
        "curl",
        "wget",
        "file",
        "libayatana-appindicator3-dev",
        "libglib2.0-dev",
        "libssl-dev",
        "librsvg2-dev",
        "libgdk3.0-cil",
        "libatk1.0-dev",
        "libgtk-3-dev"
      ],
      "version": "rust-ci"
    }
  },
  "lint": {},
  "security": {},
  "build": {
    "upload": {
      "name": "targets",
      "paths": [
        "${{ inputs.workdir }}build/release/${{ github.event.repository.name }}",
        "${{ inputs.workdir }}build/default/report.xml",
        "${{ inputs.workdir }}build/cobertura.xml"
      ]
    }
  }
}
