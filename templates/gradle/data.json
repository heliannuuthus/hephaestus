{
  "variables": {
    "inputs": [
      {
        "name": "workdir",
        "default": "./",
        "desc": "Specify all of gradle steps where are run",
        "type": "string",
        "required": "false"
      }
    ],
    "secrets": [],
    "outputs": []
  },
  "lint": {},
  "security": {},
  "build": {
    "upload": {
      "name": "targets",
      "paths": ["${{ inputs.workdir }}build/"]
    }
  }
}
